@using Praxis360_v1.Models

<P360Card Clickable="true"
          OnClick="HandleClick">

    <div class="document-layout">

        <div class="document-left">

            <div class="document-icon">
                📄
            </div>

            <div class="document-content">

                <div class="document-title">
                    @Document.Title
                </div>

                <div class="document-category">
                    @Document.Category
                </div>

                <div class="document-description">
                    @Document.Description
                </div>

                <div class="document-meta">

                    <span>@Document.FileType</span>

                    <span>•</span>

                    <span>@FormatSize(Document.FileSize)</span>

                    <span>•</span>

                    <span>@Document.DateAdded.ToString("dd/MM/yyyy")</span>

                </div>

            </div>

        </div>

        @if (Document.Favorite)
        {
            <div class="document-right">
                ⭐
            </div>
        }

    </div>

</P360Card>

@code
{
    [Parameter]
    public required Document Document { get; set; }

    [Parameter]
    public EventCallback<Guid> OnSelected { get; set; }

    private async Task HandleClick()
    {
        if (OnSelected.HasDelegate)
        {
            await OnSelected.InvokeAsync(Document.Id);
        }
    }

    private static string FormatSize(long size)
    {
        if (size >= 1024 * 1024)
            return $"{size / 1024d / 1024d:0.0} Mo";

        if (size >= 1024)
            return $"{size / 1024d:0} Ko";

        return $"{size} o";
    }
}