@using Praxis360_v1.Models

<P360Card Class="@CardClass">

    <div class="p360-category-content"
         @onclick="HandleClick">

        <div class="p360-category-icon">
            @GetIcon(Category.Icon)
        </div>

        <div class="p360-category-title">
            @Category.Title
        </div>

    </div>

</P360Card>

@code
{
    [Parameter]
    public required DocumentCategory Category { get; set; }

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string CardClass =>
        IsSelected
            ? "p360-category-card selected"
            : "p360-category-card";

    private async Task HandleClick()
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync();
    }

    private static string GetIcon(string icon)
    {
        return icon switch
        {
            "shield" => "🛡",
            "bank" => "🏦",
            "car" => "🚗",
            "house" => "🏠",
            "lightning" => "⚡",
            "folder" => "📁",
            _ => "📄"
        };
    }
}