@using Praxis360_v1.Models

@if (Documents.Any())
{
    <div class="row g-3">

        @foreach (var document in Documents)
        {
            <div class="col-12 col-md-6 col-xl-4">

                <DocumentCard Document="document"
                              OnSelected="HandleSelected" />

            </div>
        }

    </div>
}
else
{
    <div class="text-center py-5">

        <h5>Aucun document ne correspond à votre recherche</h5>

        <p class="text-muted">
            Modifiez votre recherche ou réinitialisez-la.
        </p>

    </div>
}

@code
{
    [Parameter]
    public IEnumerable<Document> Documents { get; set; } = [];

    [Parameter]
    public EventCallback<Guid> OnDocumentSelected { get; set; }

    private async Task HandleSelected(Guid id)
    {
        if (OnDocumentSelected.HasDelegate)
        {
            await OnDocumentSelected.InvokeAsync(id);
        }
    }
}