    <p>
        Retrouvez facilement vos documents et comprenez votre situation.
    </p>

    <div class="mt-4">

        <input class="form-control"
               type="text"
               placeholder="Rechercher un document, un contrat ou une facture..." />

    </div>

    <div class="mt-5 d-grid gap-3">

        <NavLink class="btn btn-outline-primary btn-lg"
                 href="/espace">
            🗂 Mon espace
