        <NavLink class="btn btn-outline-primary btn-lg"
                 href="/patrimoine">
            💼 Ma situation
        </NavLink>

        <NavLink class="btn btn-outline-primary btn-lg"
                 href="/scanner">
            📷 Scanner
        </NavLink>

    </div>

</div>