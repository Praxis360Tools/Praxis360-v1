@page "/espace"

@using Praxis360_v1.Models
@using Praxis360_v1.Services

@inject DocumentService DocumentService

<PageTitle>Mon espace</PageTitle>

<div class="container mt-4">

    <h1>Mon espace</h1>

    <p class="text-muted">
        Retrouvez facilement tous vos documents.
    </p>

    <div class="mt-4 mb-4">
        <input class="form-control"
               placeholder="🔍 Rechercher un document..."
               @bind="SearchText"
               @bind:event="oninput" />
    </div>

    <div class="row g-3 mb-4">

        @foreach (var category in Categories)
        {
            <div class="col-md-6 col-lg-4">

                <CategoryCard Category="category"
                              IsSelected="SelectedCategory == category.Title"
                              OnClick="@(() => ToggleCategory(category.Title))" />

            </div>
        }

    </div>

    <hr />

    <h4 class="mb-3">Mes documents</h4>

    <DocumentList Documents="FilteredDocuments" />

</div>

@code
{
    private IEnumerable<DocumentCategory> Categories = [];

    private IEnumerable<Document> FilteredDocuments = [];

    private string searchText = string.Empty;

    private string? SelectedCategory;

    private string SearchText
    {
        get => searchText;
        set
        {
            searchText = value;
            FilterDocuments();
        }
    }

    protected override void OnInitialized()
    {
        Categories = DocumentService.GetCategories();

        FilterDocuments();
    }

    private void ToggleCategory(string category)
    {
        if (SelectedCategory == category)
            SelectedCategory = null;
        else
            SelectedCategory = category;

        FilterDocuments();
    }

    private void FilterDocuments()
    {
        FilteredDocuments = DocumentService.GetFilteredDocuments(
            SearchText,
            SelectedCategory);
    }
}