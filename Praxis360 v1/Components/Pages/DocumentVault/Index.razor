@page "/espace"

@using Praxis360_v1.Models
@using Praxis360_v1.Services

@inject DocumentService DocumentService

<PageTitle>Mon espace</PageTitle>

<div class="container mt-4">

    <h1>Mon espace</h1>

    <p class="text-muted">
        Retrouvez facilement tous vos documents.
    </p>

    <div class="mt-4 mb-4">
        <input class="form-control"
               placeholder="🔍 Rechercher un document..."
               @bind="SearchText"
               @bind:event="oninput" />
    </div>

    <div class="row g-3 mb-4">

        @foreach (var category in Categories)
        {
            <div class="col-md-6 col-lg-4">
                <CategoryCard Title="@category.Title"
                              Url="@category.Url" />
            </div>
        }

    </div>

    <hr />

    <h4 class="mb-3">Mes documents</h4>

    <DocumentList Documents="FilteredDocuments" />

</div>

@code
{
    private IEnumerable<DocumentCategory> Categories = [];
    private IEnumerable<Document> Documents = [];

    private string searchText = string.Empty;

    private string SearchText
    {
        get => searchText;
        set
        {
            searchText = value;
            FilterDocuments();
        }
    }

    private IEnumerable<Document> FilteredDocuments = [];

    protected override void OnInitialized()
    {
        Categories = DocumentService.GetCategories();
        Documents = DocumentService.GetDocuments();

        FilterDocuments();
    }

    private void FilterDocuments()
    {
        FilteredDocuments = DocumentService.SearchDocuments(SearchText);
    }
}